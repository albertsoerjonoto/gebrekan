# Set by the Vercel-Neon integration automatically in production.
# For local dev: copy to .env.local and fill in.
DATABASE_URL=

# Any random string. Used to gate the /inbox page and /api/inbox endpoint.
ADMIN_TOKEN=

# Resend API key for confirmation emails sent from /api/submit.
# If unset, submissions still save to the DB but emails are skipped.
RESEND_API_KEY=
# Verified sender address, e.g. "gebrekan <hello@yourdomain.com>".
# Falls back to "gebrekan <onboarding@resend.dev>" (Resend's sandbox sender).
EMAIL_FROM=
